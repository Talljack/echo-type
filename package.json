{
  "name": "echotype",
  "version": "1.3.1",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "next dev",
    "build": "next build",
    "build:tauri": "bash scripts/build-tauri.sh",
    "start": "next start",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:unsigned": "tauri build --bundles app,dmg",
    "release:tag": "node scripts/create-release-tag.mjs",
    "lint": "biome check . --diagnostic-level=error",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.47",
    "@ai-sdk/cerebras": "^2.0.34",
    "@ai-sdk/cohere": "^3.0.21",
    "@ai-sdk/deepinfra": "^2.0.34",
    "@ai-sdk/google": "^3.0.33",
    "@ai-sdk/groq": "^3.0.25",
    "@ai-sdk/mistral": "^3.0.20",
    "@ai-sdk/openai": "^3.0.34",
    "@ai-sdk/openai-compatible": "^2.0.30",
    "@ai-sdk/perplexity": "^3.0.19",
    "@ai-sdk/react": "^3.0.103",
    "@ai-sdk/togetherai": "^2.0.34",
    "@ai-sdk/xai": "^3.0.59",
    "@radix-ui/react-popover": "^1.1.15",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "ai": "^6.0.101",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "edge-tts-universal": "^1.4.0",
    "fish-audio": "^0.1.0",
    "framer-motion": "^12.34.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.575.0",
    "mammoth": "^1.11.0",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "openai": "^6.25.0",
    "pdf-parse": "^2.4.5",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-speech-recognition": "^4.0.1",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "ts-fsrs": "^5.3.1",
    "use-sound": "^5.0.0",
    "youtube-transcript": "^1.2.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.10.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-speech-recognition": "^3.9.6",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "lint-staged": "^16.3.1",
    "only-allow": "^1.2.2",
    "shadcn": "^3.8.5",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{ts,tsx}": [
      "bash -c 'tsc --noEmit'"
    ]
  }
}

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# API URL (for TTS, pronunciation, translation services)
EXPO_PUBLIC_API_URL=http://localhost:3000

# SpeechSuper API (for pronunciation analysis)
EXPO_PUBLIC_SPEECHSUPER_APP_KEY=
EXPO_PUBLIC_SPEECHSUPER_SECRET_KEY=

# API Keys (optional)
EXPO_PUBLIC_OPENAI_API_KEY=
EXPO_PUBLIC_GOOGLE_CLOUD_API_KEY=
EXPO_PUBLIC_FISH_AUDIO_API_KEY=

# Sentry Error Tracking
EXPO_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Feature Flags
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_ENABLE_CRASH_REPORTING=false
